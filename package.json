{
  "name": "teste-automacao-cypress-cucumber",
  "version": "1.0.0",
  "description": "Framework de automacao de testes (Web + API) usando Cypress + Cucumber (BDD) + JavaScript, seguindo o padrao Page Object (POO)",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:run": "cypress run",
    "test": "cypress run",
    "test:web": "cypress run --spec \"cypress/e2e/features/web/**/*.feature\"",
    "test:api": "cypress run --spec \"cypress/e2e/features/api/**/*.feature\"",
    "test:chrome": "cypress run --browser chrome",
    "test:headed": "cypress run --headed --browser chrome"
  },
  "keywords": [
    "cypress",
    "cucumber",
    "bdd",
    "automation"
  ],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^20.0.3",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.2",
    "cypress": "^13.15.0",
    "esbuild": "^0.24.0"
  },
  "cypress-cucumber-preprocessor": {
    "stepDefinitions": [
      "cypress/e2e/step_definitions/**/*.{js,ts}",
      "cypress/e2e/step_definitions/common/**/*.{js,ts}"
    ]
  }
}
